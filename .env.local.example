# Local Development Configuration (XAMPP/WAMP)
# Copy this to .env if using local MySQL

APP_NAME="University Activity System"
APP_ENV=local
APP_KEY=base64:V2H2HOYamUdoQlyD3i9iy3pColPmVoKbfGx8kQ4Hm2M=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Local MySQL (XAMPP typically uses empty password)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uni_activity
DB_USERNAME=root
DB_PASSWORD=

# Alternative: If you set a password for root
# DB_PASSWORD=root

# Or create a dedicated user:
# DB_USERNAME=uni_user
# DB_PASSWORD=root

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=database
CACHE_STORE=database

REVERB_APP_ID=uni_activity_app
REVERB_APP_KEY=uni_key_123
REVERB_APP_SECRET=uni_secret_123
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
