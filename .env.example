APP_NAME="University Activity System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local: http://localhost:8000  |  Docker: http://localhost:8000
APP_URL=http://localhost:8000

APP_LOCALE=th
APP_FALLBACK_LOCALE=th
APP_FAKER_LOCALE=th_TH

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Local (XAMPP): DB_HOST=127.0.0.1, DB_PORT=3306, DB_USERNAME=root, DB_PASSWORD=
# Docker:        DB_HOST=mysql,      DB_PORT=3306, DB_USERNAME=uni_user, DB_PASSWORD=root
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=uni_activity
DB_USERNAME=uni_user
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=uni_chat
MONGO_USERNAME=root
MONGO_PASSWORD=root
MONGO_AUTH_DATABASE=admin

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Docker: REVERB_HOST=reverb (container name, PHP internal connection)
# Local:  REVERB_HOST=localhost
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Browser WebSocket connection (always use the host machine address)
# Docker: VITE_REVERB_HOST=localhost (mapped to port 8080 on host)
# Local:  VITE_REVERB_HOST=localhost
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Socket.io (Node.js real-time server)
# Docker internal: http://socketserver:3000 | Browser: http://localhost:3000
SOCKET_SERVER_URL=http://socketserver:3000
SOCKET_PUBLIC_URL=http://localhost:3000
SOCKET_SECRET=socket_secret_change_me

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
